APP_NAME=your-platform-api
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_FILE_MAX_BYTES=104857600
LOG_FILE_BACKUP_COUNT=5
DEBUG_CLEAR_DB=false

# Postgres
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/appdb
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false
RDS_SECRET_ID=
RDS_WRITER_HOST=
RDS_READER_HOST=
RDS_PORT=5432
RDS_DB_NAME=
RDS_USE_READER=false

# S3
S3_BUCKET=s114-miners-solutions

# Bittensor / Metagraph
BT_NETUID=114
BT_NETWORK=
BT_CHAIN_ENDPOINT=
BT_METAGRAPH_EPOCH_LENGTH=100
BT_METAGRAPH_SYNC_SECS=60

# Weight Setting
MAX_MINERS_FOR_WEIGHTS=1
TOP_SCREENER_SCRIPTS=0.2
PREVIOUS_COMPETITION_SCREENERS_GRACE_HOURS=4
PARTIAL_WINNERS_WEIGHT_FRACTION=0.05
SCREENER_EXTRA_MINERS_LIMIT=10
SCREENER_EXTRA_SCORE_POINTS=0.03

# Cooldown for blocking validators from new assignments after OpenRouter scoring errors (seconds)
VALIDATOR_OPENROUTER_ERROR_COOLDOWN_SECONDS=600

# Validator minimum stake weights
# total weight = alpha_stake + tao_stake * tao_weight
MIN_VALIDATOR_TOTAL_WEIGHT=30000
MIN_VALIDATOR_ALPHA_WEIGHT=5000

# QA Generator
QA_GENERATOR_MODEL=
OPENROUTER_API_KEY=

# Remote Sandbox Service Configuration (Required)
# URL of the remote sandbox service running on separate machine
SANDBOX_SERVICE_URL=http://sandbox-host:8001

# Sandbox Timeout Configuration
# Maximum execution time forwarded to one sandbox task (seconds)
SANDBOX_TIMEOUT_PER_TASK_SECONDS=10.0
# Timeout for waiting on sandbox task acceptance response (seconds)
SANDBOX_SUBMISSION_TIMEOUT_SECONDS=10.0

# SWE-Bench Orchestration
SWEBENCH_BENCHMARK_NAME=SWE-bench/SWE-bench_Verified
SWEBENCH_DEFAULT_MODEL=qwen/qwen3-coder
SWEBENCH_ORCHESTRATOR_INTERVAL_SECONDS=2.0
SWEBENCH_DISPATCH_BATCH_SIZE=8
SWEBENCH_DISPATCH_STRICT_FIFO=false
SWEBENCH_RETRY_BASE_SECONDS=5.0
SWEBENCH_RETRY_MAX_SECONDS=120.0
SWEBENCH_RETRY_JITTER_SECONDS=2.0
SWEBENCH_VALIDATION_CLAIM_TTL_SECONDS=900
SWEBENCH_SCREENING_MIN_PASSED_TASKS=0
SWEBENCH_SCREENING_PASS_RATIO=0.5
