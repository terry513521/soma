
# Service Configuration
SANDBOX_SERVICE_HOST=0.0.0.0
SANDBOX_SERVICE_PORT=8001

# Platform callback for compact-bench reports
COMPACT_BENCH_REPORT_URL=http://sandbox_private_url:port
COMPACT_BENCH_REPORT_TIMEOUT_SECONDS=15

# Optional upstream LLM/OpenAI-compatible base URL.
# When set, sandbox_service keeps one shared nginx Docker proxy and one private
# internal Docker network for benchmark containers. Benchmark/gateway containers
# can only talk over that private network and reach the upstream model endpoint through nginx.
# For OpenClaw's OpenAI-compatible HTTP API, include the /v1 prefix.
COMPACT_BENCH_LLM_BASE_URL=
COMPACT_BENCH_LLM_PROXY_IMAGE=nginx:1.27-alpine
COMPACT_BENCH_LLM_PROXY_PORT=8080
COMPACT_BENCH_PRIVATE_NETWORK_NAME=soma-compact-bench-private

# Callback reliability / retries
COMPACT_BENCH_CALLBACK_QUEUE_PATH=/var/lib/soma-sandbox/callback_queue.sqlite3
COMPACT_BENCH_CALLBACK_RETRY_POLL_SECONDS=1
COMPACT_BENCH_CALLBACK_RETRY_BASE_SECONDS=2
COMPACT_BENCH_CALLBACK_RETRY_MAX_SECONDS=300

# Capacity flood protection
COMPACT_BENCH_CAPACITY_COOLDOWN_SECONDS=2

# nginx proxy timeout/keepalive tuning
COMPACT_BENCH_NGINX_PROXY_CONNECT_TIMEOUT_SECONDS=30
COMPACT_BENCH_NGINX_PROXY_SEND_TIMEOUT_SECONDS=1800
COMPACT_BENCH_NGINX_PROXY_READ_TIMEOUT_SECONDS=1800
COMPACT_BENCH_NGINX_PROXY_KEEPALIVE_TIMEOUT_SECONDS=75

# OpenClaw WS watchdog (retry only GatewayTransportError 1006)
SOMA_OPENCLAW_WS_WATCHDOG_RETRIES=1
SOMA_OPENCLAW_WS_WATCHDOG_BACKOFF_SECONDS=1
