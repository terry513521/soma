## Validator core
# Wallet name (bittensor wallet)
WALLET_NAME=
# Wallet hotkey (bittensor hotkey name)
WALLET_HOTKEY=
# Bittensor netuid (default: 114)
NETUID=114

# Bittensor network (finney, test, local)
BT_NETWORK=finney

# Platform API base URL
PLATFORM_URL=https://platform.thesoma.ai
# Platform signer SS58 (used to verify responses)
PLATFORM_SIGNER_SS58=5H1nRfbCbDGh3t17er9Y8hwFEsXCrjBbaN6jLrnez8KpUKju

# Validator bind host and port
# Provide a public IP address, so it can be accessed by the platform.
VALIDATOR_HOST=
VALIDATOR_PORT=8000

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Poll interval for fetching tasks (seconds)
TASK_POLL_INTERVAL_SECONDS=15
# Maximum backoff interval when no tasks available (seconds)
MAX_BACKOFF_INTERVAL_SECONDS=300
# Backoff multiplier for exponential backoff
BACKOFF_MULTIPLIER=2.0

# Max concurrent evaluations (default: CPU count - 1, max 8)
MAX_CONCURRENT_EVALUATIONS=4

## SWE-Bench scoring
# Most SWE-Bench defaults are defined inline in `Settings.from_env()`.
# The harness is expected to be installed with validator dependencies.
# Keep `.env` for local overrides only; uncomment what you actually need to change.

# Optional Hugging Face token used automatically by `huggingface_hub` / `datasets`
# for higher rate limits when loading SWE-Bench data.
# HF_TOKEN=

# Cooldown after scoring failures before fetching new tasks again (seconds)
# SCORING_ERROR_COOLDOWN_SECONDS=600

# Shorter cooldown used specifically for Hugging Face rate-limit responses (HTTP 429)
# HF_RATE_LIMIT_COOLDOWN_SECONDS=120

# Common runtime overrides
# SWEBENCH_EVAL_ARCH=x86_64
# SWEBENCH_EVAL_TIMEOUT_SECONDS=1800
# SWEBENCH_EVAL_REMOVE_IMAGE_AFTER_RUN=true
